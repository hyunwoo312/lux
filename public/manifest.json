{
  "manifest_version": 3,
  "name": "Lux",
  "version": "1.0.0",
  "description": "A customizable new tab dashboard with widgets and much more.",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "minimum_chrome_version": "120",
  "key": "",
  "permissions": [
    "storage",
    "favicon",
    "identity"
  ],
  "optional_permissions": [
    "bookmarks",
    "history",
    "sessions",
    "topSites"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://graph.microsoft.com/*",
    "https://login.microsoftonline.com/*",
    "https://api.spotify.com/*",
    "https://accounts.spotify.com/*",
    "https://api.github.com/*",
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://graphql.anilist.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://lux.hyunwk.me/anilist/callback*"],
      "js": ["anilist-callback.js"],
      "run_at": "document_start"
    }
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
