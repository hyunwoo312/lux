{
  "manifest_version": 3,
  "name": "Lux",
  "version": "1.0.0",
  "description": "A customizable new tab dashboard with widgets and much more.",
  "minimum_chrome_version": "120",
  "key": "",
  "permissions": ["storage", "favicon", "bookmarks", "history", "sessions", "identity"],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://graph.microsoft.com/*",
    "https://login.microsoftonline.com/*",
    "https://api.spotify.com/*",
    "https://accounts.spotify.com/*"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
