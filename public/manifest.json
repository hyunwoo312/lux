{
  "manifest_version": 3,
  "name": "Lux",
  "version": "1.0.0",
  "description": "A customizable new tab dashboard with widgets and much more.",
  "minimum_chrome_version": "120",
  "permissions": ["storage", "favicon", "bookmarks", "history", "sessions"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
